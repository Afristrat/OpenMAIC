{
  "id": "code-sandbox",
  "type": "code-sandbox",
  "name": {
    "fr": "Bac a sable de code",
    "ar": "\u0628\u064a\u0626\u0629 \u0627\u0644\u0628\u0631\u0645\u062c\u0629",
    "en": "Code Sandbox"
  },
  "description": {
    "fr": "Editeur de code interactif avec execution JavaScript et Python (Pyodide)",
    "ar": "\u0645\u062d\u0631\u0631 \u0643\u0648\u062f \u062a\u0641\u0627\u0639\u0644\u064a \u0645\u0639 \u062a\u0646\u0641\u064a\u0630 JavaScript \u0648 Python",
    "en": "Interactive code editor with JavaScript and Python (Pyodide) execution"
  },
  "version": "1.0.0",
  "author": "Qalem",
  "renderUrl": "index.html",
  "icon": "Code",
  "systemPrompt": "",
  "outputSchema": {
    "type": "object",
    "properties": {
      "language": {
        "type": "string",
        "enum": ["javascript", "python"],
        "description": "Programming language for the exercise"
      },
      "title": {
        "type": "string",
        "description": "Exercise title"
      },
      "instructions": {
        "type": "string",
        "description": "Markdown instructions shown to the student"
      },
      "starterCode": {
        "type": "string",
        "description": "Initial code in the editor"
      },
      "solution": {
        "type": "string",
        "description": "Reference solution (hidden from student)"
      },
      "tests": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "input": { "type": "string" },
            "expected": { "type": "string" }
          },
          "required": ["name", "expected"]
        },
        "description": "Test cases for auto-grading"
      }
    },
    "required": ["language", "title", "instructions", "starterCode", "tests"]
  },
  "supportedActions": ["run-code", "reset", "show-solution"]
}
